APP_NAME=Constituency Intelligence Platform
APP_VERSION=1.0.0

ENVIRONMENT=development
DEBUG=false

API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg_async://postgres:postgres@127.0.0.1:5432/cip

# REQUIRED: Generate a secure random key for JWT signing.
# Example: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=changeme-generate-a-real-secret

BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# LLM Configuration (Ollama for local dev, OpenAI for production)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3:1.7b

# Geospatial (optional for development)
# GOOGLE_MAPS_API_KEY=your-key-here